# Garmin OAuth session tokens — treated like a password, never commit
.garth_session/

# .env file — only .env.example should be committed
.env

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# User-specific data preferences (not sensitive but personal)
settings.json

# Cached Garmin health data — regenerated on each run
garmin_data.json

# Persisted chat history — personal conversation data
chat_history.json

# Daily digest log
digest.log

# Claude Code internal files
.claude/
